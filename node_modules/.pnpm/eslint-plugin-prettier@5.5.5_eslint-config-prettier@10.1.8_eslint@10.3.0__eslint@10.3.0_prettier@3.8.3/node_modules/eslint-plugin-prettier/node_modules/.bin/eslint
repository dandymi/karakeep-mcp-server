#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/agent/project/karakeep-mcp-server/node_modules/.pnpm/eslint@10.3.0/node_modules/eslint/node_modules:/home/agent/project/karakeep-mcp-server/node_modules/.pnpm/eslint@10.3.0/node_modules:/home/agent/project/karakeep-mcp-server/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/agent/project/karakeep-mcp-server/node_modules/.pnpm/eslint@10.3.0/node_modules/eslint/node_modules:/home/agent/project/karakeep-mcp-server/node_modules/.pnpm/eslint@10.3.0/node_modules:/home/agent/project/karakeep-mcp-server/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../eslint/bin/eslint.js" "$@"
else
  exec node  "$basedir/../../../eslint/bin/eslint.js" "$@"
fi
